# Токен бота (получить у @BotFather)
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# LLM: openai | claude
LLM_PROVIDER=openai

# --- OpenAI ---
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=                    # оставить пустым для OpenAI

# --- DeepSeek (пример) ---
# LLM_PROVIDER=openai
# LLM_MODEL=deepseek-chat
# OPENAI_API_KEY=sk-...               # ключ DeepSeek (platform.deepseek.com)
# OPENAI_BASE_URL=https://api.deepseek.com

# --- Claude ---
# LLM_PROVIDER=claude
# LLM_MODEL=claude-3-haiku-20240307
# ANTHROPIC_API_KEY=sk-ant-...

# ID каналов/групп через запятую. Оставьте пустым чтобы слушать ВСЕ группы с ботом.
CHANNEL_IDS=-1001234567890,-1009876543210

# Бот активен сразу после запуска/restart. Установите 0, если нужен ручной /start.
BOT_AUTO_START=1

# Вероятность предложить LLM одну контекстную фразу Максима (0..1).
# Фраза не дописывается механически: модель может её проигнорировать.
STYLE_CUE_PROBABILITY=0.20
